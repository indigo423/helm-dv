extends: default
rules:
  document-start: disable
  line-length: disable
  comments:
    min-spaces-from-content: 1
  truthy:
    # Allow GitHub Actions `on:` and Helm boolean keys.
    check-keys: false
  braces:
    max-spaces-inside: 1
  indentation:
    spaces: consistent
    indent-sequences: whatever
